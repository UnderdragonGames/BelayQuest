{
  "expo": {
    "name": "Belay Quest",
    "slug": "belay-quest",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "belayquest",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2a1f14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "quest.belay.app",
      "associatedDomains": [
        "applinks:belay.quest"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSContactsUsageDescription": "BelayQuest uses your contacts to help you invite climbing partners."
      }
    },
    "android": {
      "package": "quest.belay.app",
      "adaptiveIcon": {
        "backgroundColor": "#2a1f14",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "belay.quest",
              "pathPrefix": "/j/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-contacts",
        {
          "contactsPermission": "BelayQuest uses your contacts to help you invite climbing partners."
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e0e5c53c-8a45-46d2-89ce-8d361d561f7d"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e0e5c53c-8a45-46d2-89ce-8d361d561f7d"
      }
    },
    "owner": "buishi"
  }
}
